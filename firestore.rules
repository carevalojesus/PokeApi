rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdminUser(uid) {
      return get(/databases/$(database)/documents/trainers/$(uid)).data.role == 'admin';
    }

    function isAdmin() {
      return signedIn() && isAdminUser(request.auth.uid);
    }

    function validTrainerBase(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'role',
          'displayName',
          'firstName',
          'lastName',
          'birthDate',
          'gender',
          'ownedPokemonCount',
          'unlockedPokemonCount',
          'points',
          'createdAt',
          'updatedAt',
          'lastClaimAt',
          'profilePhotoUrl',
          'lastSeen',
          'starterChosen',
          'starterPokemonId',
          'starterChangesRemaining'
        ]) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'role', 'displayName']) &&
        request.resource.data.uid == uid &&
        request.resource.data.email is string &&
        request.resource.data.displayName is string &&
        request.resource.data.role == 'trainer' &&
        (!('starterChosen' in request.resource.data) || request.resource.data.starterChosen is bool) &&
        (!('starterPokemonId' in request.resource.data) || (request.resource.data.starterPokemonId is int && request.resource.data.starterPokemonId >= 0 && request.resource.data.starterPokemonId <= 151)) &&
        (!('starterChangesRemaining' in request.resource.data) || (request.resource.data.starterChangesRemaining is int && request.resource.data.starterChangesRemaining >= 0 && request.resource.data.starterChangesRemaining <= 3)) &&
        (!('firstName' in request.resource.data) || request.resource.data.firstName is string) &&
        (!('lastName' in request.resource.data) || request.resource.data.lastName is string) &&
        (!('birthDate' in request.resource.data) || request.resource.data.birthDate is string) &&
        (!('gender' in request.resource.data) || request.resource.data.gender is string) &&
        (!('ownedPokemonCount' in request.resource.data) || (request.resource.data.ownedPokemonCount is int && request.resource.data.ownedPokemonCount >= 0)) &&
        (!('unlockedPokemonCount' in request.resource.data) || (request.resource.data.unlockedPokemonCount is int && request.resource.data.unlockedPokemonCount >= 0)) &&
        (!('points' in request.resource.data) || (request.resource.data.points is int && request.resource.data.points >= 0 && request.resource.data.points <= 1000000));
    }

    function validTrainerSelfUpdate(uid) {
      return request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'firstName',
          'lastName',
          'birthDate',
          'gender',
          'updatedAt',
          'lastClaimAt',
          'ownedPokemonCount',
          'unlockedPokemonCount',
          'points',
          'profilePhotoUrl',
          'lastSeen',
          'starterChosen',
          'starterPokemonId',
          'starterChangesRemaining'
        ]) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.displayName is string &&
        (!('starterChosen' in request.resource.data) || request.resource.data.starterChosen is bool) &&
        (!('starterPokemonId' in request.resource.data) || (request.resource.data.starterPokemonId is int && request.resource.data.starterPokemonId >= 0 && request.resource.data.starterPokemonId <= 151)) &&
        (!('starterChangesRemaining' in request.resource.data) || (request.resource.data.starterChangesRemaining is int && request.resource.data.starterChangesRemaining >= 0 && request.resource.data.starterChangesRemaining <= 3)) &&
        (!('firstName' in request.resource.data) || request.resource.data.firstName is string) &&
        (!('lastName' in request.resource.data) || request.resource.data.lastName is string) &&
        (!('birthDate' in request.resource.data) || request.resource.data.birthDate is string) &&
        (!('gender' in request.resource.data) || request.resource.data.gender is string) &&
        (!('ownedPokemonCount' in request.resource.data) || (request.resource.data.ownedPokemonCount is int && request.resource.data.ownedPokemonCount >= 0)) &&
        (!('unlockedPokemonCount' in request.resource.data) || (request.resource.data.unlockedPokemonCount is int && request.resource.data.unlockedPokemonCount >= 0)) &&
        (!('points' in request.resource.data) || (request.resource.data.points is int && request.resource.data.points >= 0 && request.resource.data.points <= 1000000));
    }

    function validInventoryPayload() {
      return request.resource.data.keys().hasOnly(['pokemonId', 'count', 'updatedAt']) &&
        request.resource.data.keys().hasAll(['pokemonId', 'count']) &&
        request.resource.data.pokemonId is int &&
        request.resource.data.count is int &&
        request.resource.data.pokemonId >= 1 &&
        request.resource.data.pokemonId <= 151 &&
        request.resource.data.count >= 0 &&
        request.resource.data.count <= 999;
    }

    function validMissionEventPayload() {
      return request.resource.data.keys().hasOnly(['eventKey', 'category', 'pointsAwarded', 'createdAt']) &&
        request.resource.data.keys().hasAll(['eventKey', 'category', 'pointsAwarded']) &&
        request.resource.data.eventKey is string &&
        request.resource.data.category is string &&
        request.resource.data.pointsAwarded is int &&
        request.resource.data.pointsAwarded >= 0 &&
        request.resource.data.pointsAwarded <= 1000;
    }

    function validPetCarePayload() {
      return request.resource.data.keys().hasOnly([
          'pokemonId',
          'hunger',
          'energy',
          'happiness',
          'sleeping',
          'updatedAtMillis',
          'neglectSinceMillis',
          'lastPenaltyAtMillis',
          'neglectStrikes',
          'updatedAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'pokemonId',
          'hunger',
          'energy',
          'happiness',
          'sleeping',
          'updatedAtMillis',
          'neglectSinceMillis',
          'lastPenaltyAtMillis',
          'neglectStrikes'
        ]) &&
        request.resource.data.pokemonId is int &&
        request.resource.data.pokemonId >= 1 &&
        request.resource.data.pokemonId <= 151 &&
        request.resource.data.hunger is int &&
        request.resource.data.hunger >= 0 &&
        request.resource.data.hunger <= 100 &&
        request.resource.data.energy is int &&
        request.resource.data.energy >= 0 &&
        request.resource.data.energy <= 100 &&
        request.resource.data.happiness is int &&
        request.resource.data.happiness >= 0 &&
        request.resource.data.happiness <= 100 &&
        request.resource.data.sleeping is bool &&
        request.resource.data.updatedAtMillis is int &&
        request.resource.data.updatedAtMillis >= 0 &&
        request.resource.data.neglectSinceMillis is int &&
        request.resource.data.neglectSinceMillis >= 0 &&
        request.resource.data.lastPenaltyAtMillis is int &&
        request.resource.data.lastPenaltyAtMillis >= 0 &&
        request.resource.data.neglectStrikes is int &&
        request.resource.data.neglectStrikes >= 0 &&
        request.resource.data.neglectStrikes <= 99;
    }

    function validUnlockedPayload() {
      return request.resource.data.keys().hasOnly(['pokemonId', 'unlockedAt']) &&
        request.resource.data.keys().hasAll(['pokemonId']) &&
        request.resource.data.pokemonId is int &&
        request.resource.data.pokemonId >= 1 &&
        request.resource.data.pokemonId <= 151;
    }

    function validNotificationCreatePayload() {
      return request.resource.data.keys().hasOnly([
          'title',
          'message',
          'type',
          'read',
          'createdAt',
          'createdBy'
        ]) &&
        request.resource.data.keys().hasAll([
          'title',
          'message',
          'type',
          'read',
          'createdAt',
          'createdBy'
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.message is string &&
        request.resource.data.type is string &&
        request.resource.data.read is bool &&
        request.resource.data.read == false &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.message.size() <= 500;
    }

    function validNotificationSelfUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']) &&
        request.resource.data.read is bool &&
        request.resource.data.read == true;
    }

    function validCampaignCodeCreate() {
      return request.resource.data.keys().hasOnly([
          'codeId',
          'payload',
          'index',
          'active',
          'createdAt'
        ]) &&
        request.resource.data.keys().hasAll(['codeId', 'payload', 'index', 'active']) &&
        request.resource.data.codeId is string &&
        request.resource.data.codeId.size() >= 8 &&
        request.resource.data.payload is string &&
        request.resource.data.payload.size() <= 300 &&
        request.resource.data.index is int &&
        request.resource.data.index >= 1 &&
        request.resource.data.index <= 10000 &&
        request.resource.data.active == true;
    }

    function validCampaignCodeClaimUpdate() {
      return request.resource.data.keys().hasOnly([
          'codeId',
          'payload',
          'index',
          'active',
          'createdAt',
          'claimedBy',
          'claimedAt'
        ]) &&
        resource.data.active == true &&
        request.resource.data.codeId == resource.data.codeId &&
        request.resource.data.payload == resource.data.payload &&
        request.resource.data.index == resource.data.index &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.active == false &&
        request.resource.data.claimedBy == request.auth.uid &&
        request.resource.data.claimedAt is timestamp;
    }

    match /trainers/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && (
        isAdmin() ||
        (request.auth.uid == uid && validTrainerBase(uid))
      );
      allow update: if signedIn() && (
        isAdmin() ||
        validTrainerSelfUpdate(uid)
      );
      allow delete: if isAdmin();

      match /inventory/{pokemonId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() &&
          request.auth.uid == uid &&
          validInventoryPayload();
        allow update: if signedIn() &&
          request.auth.uid == uid &&
          validInventoryPayload() &&
          request.resource.data.pokemonId == resource.data.pokemonId;
        allow delete: if isAdmin();
      }

      match /notifications/{notificationId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() && validNotificationCreatePayload() && (
          (isAdmin() && request.resource.data.type in ['admin_broadcast', 'new_trainer', 'general']) ||
          (request.resource.data.type == 'new_trainer' && isAdminUser(uid))
        );
        allow update: if signedIn() && (
          isAdmin() ||
          (request.auth.uid == uid && validNotificationSelfUpdate())
        );
        allow delete: if signedIn() && isAdmin();
      }

      match /mission_events/{eventId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() &&
          request.auth.uid == uid &&
          validMissionEventPayload();
        allow update: if false;
        allow delete: if isAdmin();
      }

      match /unlocked/{pokemonId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() &&
          request.auth.uid == uid &&
          validUnlockedPayload();
        allow update: if signedIn() &&
          request.auth.uid == uid &&
          validUnlockedPayload() &&
          request.resource.data.pokemonId == resource.data.pokemonId;
        allow delete: if isAdmin();
      }

      match /pet_care/{pokemonId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() &&
          request.auth.uid == uid &&
          validPetCarePayload();
        allow update: if signedIn() &&
          request.auth.uid == uid &&
          validPetCarePayload() &&
          request.resource.data.pokemonId == resource.data.pokemonId;
        allow delete: if isAdmin();
      }

      match /favorites/{pokemonId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create, update: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow delete: if signedIn() && (request.auth.uid == uid || isAdmin());
      }

      match /marketplace/{itemId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create, update: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow delete: if signedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    match /trades/{tradeId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.creatorUid == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.keys().hasAll([
          'tradeId', 'creatorUid', 'offerPokemonId', 'requestPokemonId',
          'offerPokemonName', 'requestPokemonName', 'status', 'createdAt'
        ]);
      allow update: if signedIn() && (
        // pending → accepted: only non-creator
        (resource.data.status == 'pending' &&
         request.resource.data.status == 'accepted' &&
         request.auth.uid != resource.data.creatorUid &&
         request.resource.data.acceptorUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'status', 'acceptorUid', 'acceptedAt'
         ])
        ) ||
        // accepted → completed: only creator
        (resource.data.status == 'accepted' &&
         request.resource.data.status == 'completed' &&
         request.auth.uid == resource.data.creatorUid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'status', 'completedAt'
         ])
        )
      );
      allow delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /codes/{codeId} {
        allow read: if signedIn();
        allow create: if isAdmin() && validCampaignCodeCreate();
        allow update: if signedIn() && validCampaignCodeClaimUpdate();
        allow delete: if isAdmin();
      }

      match /claims/{uid} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() && request.auth.uid == uid;
        allow update: if false;
        allow delete: if isAdmin();
      }
    }
  }
}
